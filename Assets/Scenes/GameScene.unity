  m_Script: {fileID: 11500000, guid: 25742014a4b4cfa4182bc652c883f7d9, type: 3}
  m_Name: 
  m_EditorClassIdentifier: '::'
  dialoguePanel: {fileID: 198296088}
  dialogueText: {fileID: 1462835865}
  npcNameText: {fileID: 823376963}
  dialogue:
  - I've never seen a face like yours around here
  - These plants make me feel quite tranquil amisdt a world where robot kin like
    me have littered the place
  - I was given the purpose of caring for any plants assigned to me
  - However, the people who assigned me that purpose have long since passed, and
    i'm only left to with to do what my internal programming tells me to
  - 'Care to smell the flowers? I''d say it''s great scenery '
  npcName: Lone Botanist
  continueButton: {fileID: 124852682}
  wordSpeed: 0.05
  playerIsClose: 0
  npcImage: {fileID: 1460025418}
  npcSprite: {fileID: 7073070410251925405, guid: b4f0e99f99877ad499416f5aa2379be2, type: 3}
