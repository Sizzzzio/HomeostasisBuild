  m_Script: {fileID: 11500000, guid: bbad6e8aa6b0e3a4894e5f21577fc09d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCBehavior
  dialogue:
    characterName: Botanaton
    sentences:
    - "Ah\u2026 a visitor. It has been some time.\n"
    - "I was once a keeper of systems\u2026 now I tend to growth.\n"
    - 'Must one side erase the other to exist?

'
    - 'Balance is not given. It is maintained.

'
    - "You still have a choice\u2026"
  dialogueSystem: {fileID: 0}
  range: 2
