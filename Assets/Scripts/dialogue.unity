    characterName: Crumbling Vessel
    sentences:
    - "\u2026another\u2026 vessel\u2026"
    - "I was\u2026 like you\u2026 once\u2026\n"
    - "Nature\u2026 machine\u2026 all the same\u2026 in the end\u2026\n"
    - "Cycle\u2026 never ends\u2026\n"
    - "Will you\u2026 help me\u2026?"
